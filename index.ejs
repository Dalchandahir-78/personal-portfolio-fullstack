<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VIP Portfolio</title>
    <!-- Fonts, Icons, and ScrollReveal Animations -->
    <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;700;800&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/scrollreveal"></script>
   <link rel="stylesheet" href="/style.css">
</head>
<body>

    <!-- Animated Premium Backdrops -->
    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <!-- Navigation Bar -->
    <header>
        <div class="nav-container">
            <a href="#" class="logo">Enginee<span>R</span></a>
            <nav>
                <a href="#home" class="active">Home</a>
                <a href="#about">About</a>
                <a href="#skills">Skills</a>
                <a href="#education">Education</a>
                <a href="#internship">Internship</a>
                <a href="#contact" class="nav-btn">Hire Me</a>
            </nav>
        </div>
    </header>



    <!-- Home / Hero Section -->
    <section id="home" class="hero">
        <div class="hero-container">
            <!-- Left Side: Content -->
            <div class="hero-text">
                <div class="tag-reveal"><span>✦ Welcome to my websites</span></div>
                <h1>Hi, I am <br><span class="highlight text-gradient">Dalchand Ahirwar</span></h1>
                <h2>Creative <span class="typewriter"></span></h2>
                <p>I build high-end web architectures, combining absolute performance with cinematic user interfaces that convert clients instantly.</p>
                <div class="hero-btns">
                    <a href="#contact" class="btn btn-prime">Let's Connect <i class="fa-solid fa-arrow-right"></i></a>
                    <a href="#internship" class="btn btn-sec">View Experience</a>
                </div>
            </div>
            
            <!-- Right Side: VIP Animated Image Box -->
            <div class="hero-image-wrapper">
                <div class="image-glow-effect"></div>
                <div class="image-box">
                    <!-- Aap apni photo ka link yahan 'src' mein daal sakte hain -->
                    <img src="me.jpg" alt="<%= data.name %> Image">
                </div>
                <!-- Extra Decorative Element for VIP Look -->
                <div class="floating-badge">
                    <i class="fa-solid fa-code"></i>
                    <span>Expert</span>
                </div>
            </div>
        </div>
    </section>



 

    <!-- About Section -->
    <section id="about" class="about">
        <h2 class="section-title">About Me</h2>
        <div class="about-grid">
            <div class="about-box reveal-left">
                <h3>My Philosophy</h3>
                <p>Main hamesha aisi websites banata hu jo na sirf dikhne me luxurious ho, balki speed aur coding architecture me bhi standard follow karein. Client satisfaction aur pixel-perfect delivery meri sabse badi priority hai.</p>
            </div>
            <div class="about-box reveal-right highlight-box">
                <h3>Why Work With Me?</h3>
                <ul class="custom-list">
                    <li><i class="fa-solid fa-circle-check"></i> Super Smooth VIP Animations</li>
                    <li><i class="fa-solid fa-circle-check"></i> Clean and Scalable Backend Architecture</li>
                    <li><i class="fa-solid fa-circle-check"></i> Responsive Layout (Mobile Friendly)</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
     <!-- Skills Section -->
    <section id="skills" class="skills">
        <h2 class="section-title">Technical Expertise</h2>
        <p class="section-subtitle">My core professional capabilities and software proficiencies</p>

        <!-- Category 1: Web Development & Databases -->
        <h3 class="skills-category-title"><i class="fa-solid fa-code"></i> Web Development & Databases</h3>
        <div class="skills-container m-bottom">
            
            <!-- HTML5 -->
            <div class="skill-card-vip hover-glow-orange">
                <div class="skill-header">
                    <i class="fa-brands fa-html5 text-orange"></i>
                    <div class="skill-info">
                        <h4>HTML5</h4>
                        <span class="skill-percentage">95%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 95%; background: #f97316;"></span></div>
            </div>

            <!-- CSS3 -->
            <div class="skill-card-vip hover-glow-blue">
                <div class="skill-header">
                    <i class="fa-brands fa-css3-alt text-blue"></i>
                    <div class="skill-info">
                        <h4>CSS3 Architecture</h4>
                        <span class="skill-percentage">90%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 90%; background: #3b82f6;"></span></div>
            </div>

            <!-- JavaScript -->
            <div class="skill-card-vip hover-glow-yellow">
                <div class="skill-header">
                    <i class="fa-brands fa-js text-yellow"></i>
                    <div class="skill-info">
                        <h4>JavaScript (ES6+)</h4>
                        <span class="skill-percentage">85%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 85%; background: #eab308;"></span></div>
            </div>

            <!-- PHP -->
            <div class="skill-card-vip hover-glow-purple">
                <div class="skill-header">
                    <i class="fa-brands fa-php text-purple"></i>
                    <div class="skill-info">
                        <h4>PHP Backend</h4>
                        <span class="skill-percentage">80%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 80%; background: #a855f7;"></span></div>
            </div>

            <!-- MySQL -->
            <div class="skill-card-vip hover-glow-cyan">
                <div class="skill-header">
                    <i class="fa-solid fa-database text-cyan"></i>
                    <div class="skill-info">
                        <h4>MySQL Database</h4>
                        <span class="skill-percentage">85%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 85%; background: #06b6d4;"></span></div>
            </div>

            <!-- Python Basic -->
            <div class="skill-card-vip hover-glow-green">
                <div class="skill-header">
                    <i class="fa-brands fa-python text-green"></i>
                    <div class="skill-info">
                        <h4>Python (Basics)</h4>
                        <span class="skill-percentage">65%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 65%; background: #22c55e;"></span></div>
            </div>

        </div>

        <!-- Category 2: Microsoft Office Suite -->
        <h3 class="skills-category-title"><i class="fa-solid fa-briefcase"></i> Professional Office Suite</h3>
        <div class="skills-container">

            <!-- Excel -->
            <div class="skill-card-vip hover-glow-excel">
                <div class="skill-header">
                    <i class="fa-regular fa-file-excel text-excel"></i>
                    <div class="skill-info">
                        <h4>Microsoft Excel</h4>
                        <span class="skill-percentage">90%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 90%; background: #107c41;"></span></div>
            </div>

            <!-- MS Word -->
            <div class="skill-card-vip hover-glow-word">
                <div class="skill-header">
                    <i class="fa-regular fa-file-word text-word"></i>
                    <div class="skill-info">
                        <h4>Microsoft Word</h4>
                        <span class="skill-percentage">95%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 95%; background: #2b579a;"></span></div>
            </div>

            <!-- PowerPoint -->
            <div class="skill-card-vip hover-glow-powerpoint">
                <div class="skill-header">
                    <i class="fa-regular fa-file-powerpoint text-powerpoint"></i>
                    <div class="skill-info">
                        <h4>MS PowerPoint</h4>
                        <span class="skill-percentage">85%</span>
                    </div>
                </div>
                <div class="progress-line"><span style="width: 85%; background: #d24726;"></span></div>
            </div>

        </div>
    </section>
