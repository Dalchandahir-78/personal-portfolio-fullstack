    <section id="contact" class="vip-contact-section">
    <div class="vip-contact-container">
        
        <div class="vip-info-panel">
            <span class="status-badge"><i class="fa-solid fa-bolt"></i> Available for Elite Projects</span>
            <h2 class="vip-panel-title">Let's Build Something <br><span class="neon-text-gradient">Legendary</span></h2>
            <p class="vip-panel-desc">Have a complex application system, architectural blueprint, or premium design request? Secure a direct encrypted line with me.</p>
            
            <div class="vip-meta-list">
                <div class="vip-meta-item">
                    <div class="vip-meta-icon"><i class="fa-solid fa-envelope-open-text"></i></div>
                    <div class="vip-meta-text">
                        <span>Direct Electronic Mail</span>
                        <p>dalchandahirwar49@gmail.com</p>
                    </div>
                </div>
                <div class="vip-meta-item">
                    <div class="vip-meta-icon"><i class="fa-solid fa-location-crosshairs"></i></div>
                    <div class="vip-meta-text">
                        <span>Current Headquarters</span>
                        <p>Madhya Pradesh, India</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="vip-form-panel">
            <div class="ambient-glow-halo"></div>
            <form action="/contact" method="POST" class="vip-interactive-form">
                <h3 class="vip-form-title">Secure Transmission Terminal</h3>
                
                <div class="vip-input-group">
                    <input type="text" name="name" required placeholder=" ">
                    <label><i class="fa-regular fa-user"></i> Full Name</label>
                    <span class="animated-focus-border"></span>
                </div>

                <div class="vip-input-group">
                    <input type="email" name="email" required placeholder=" ">
                    <label><i class="fa-regular fa-envelope"></i> Email Address</label>
                    <span class="animated-focus-border"></span>
                </div>

                <div class="vip-input-group">
                    <textarea name="message" rows="5" required placeholder=" "></textarea>
                    <label><i class="fa-regular fa-comment-dots"></i> Project Architecture / Specs</label>
                    <span class="animated-focus-border"></span>
                </div>

                <button type="submit" class="vip-submit-trigger">
                    <span>Initialize Dispatch</span>
                    <i class="fa-solid fa-paper-plane rocket-icon"></i>
                </button>
            </form>
        </div>

    </div>
</section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 <%= data.name %>. Engineered with absolute luxury.</p>
    </footer>

    <script src="/main.js"></script>
