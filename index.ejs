    <!-- Education Section -->
    <section id="education" class="education">
        <h2 class="section-title">Academic Journey</h2>
        <p class="section-subtitle">My academic foundations and specialized technical qualification track</p>

        <div class="timeline-vip">
            <!-- Global Vertical Line Decorative Glow -->
            <div class="timeline-line-glow"></div>

            <!-- B.Tech (Current Pursuing) -->
            <div class="timeline-item-vip reveal-left">
                <div class="timeline-dot-vip glowing-dot-blue">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div class="timeline-content-vip border-glow-blue">
                    <div class="timeline-header">
                        <span class="status-tag pursuing">Pursuing</span>
                        <h3 class="degree-title">B.Tech in Computer Science & Engineering</h3>
                    </div>
                    <h4 class="specialization-tag"><i class="fa-solid fa-cubes"></i> Specialization: Blockchain Technology</h4>
                    <p class="institution-name"><i class="fa-solid fa-building-columns"></i> Samrat Ashok Technological Institute (SATI), Vidisha</p>
                    <div class="academic-footer">
                        <span class="edu-meta"><i class="fa-regular fa-calendar"></i> Current Track</span>
                    </div>
                </div>
            </div>

            <!-- Diploma (RGPV Bhopal) -->
            <div class="timeline-item-vip reveal-right">
                <div class="timeline-dot-vip glowing-dot-purple">
                    <i class="fa-solid fa-award"></i>
                </div>
                <div class="timeline-content-vip border-glow-purple">
                    <div class="timeline-header">
                        <span class="status-tag completed">Passout 2024</span>
                        <h3 class="degree-title">Diploma in Computer Science & Engineering</h3>
                    </div>
                    <p class="institution-name"><i class="fa-solid fa-building-columns"></i> Govt. Polytechnic College, Damoh</p>
                    <div class="academic-footer">
                        <span class="edu-meta"><i class="fa-solid fa-gavel"></i> University: RGPV, Bhopal</span>
                    </div>
                </div>
            </div>

            <!-- 10th (MP Board) -->
            <div class="timeline-item-vip reveal-left">
                <div class="timeline-dot-vip glowing-dot-orange">
                    <i class="fa-solid fa-school"></i>
                </div>
                <div class="timeline-content-vip border-glow-orange">
                    <div class="timeline-header">
                        <span class="status-tag completed">Passout 2021</span>
                        <h3 class="degree-title">High School Examination (10th)</h3>
                    </div>
                    <p class="institution-name"><i class="fa-solid fa-building-columns"></i> Govt. HSS, Sitanagar</p>
                    <div class="academic-footer">
                        <span class="edu-meta"><i class="fa-solid fa-landmark"></i> MP Board (MPBSE)</span>
                        <span class="score-badge"><i class="fa-solid fa-chart-simple"></i> Score: 79%</span>
                    </div>
                </div>
            </div>

        </div>
    </section>

    
    <!-- VIP Internship Section -->
    <section id="internship" class="internship">
        <h2 class="section-title">Internship Experience</h2>
        <p class="section-subtitle">Real-world software engineering exposure and tactical project delivery</p>

        <!-- CodSoft Corporate Showcase Card -->
        <div class="intern-corporate-card reveal-top">
            <div class="corporate-header">
                <div class="corp-branding">
                    <div class="corp-logo-box">
                        <i class="fa-solid fa-laptop-code"></i>
                    </div>
                    <div class="corp-title">
                        <h3>Web Development Intern</h3>
                        <h4>CodSoft <span class="badge-online"><i class="fa-solid fa-globe"></i> Virtual / Online</span></h4>
                    </div>
                </div>
                <div class="corp-duration">
                    <i class="fa-regular fa-calendar-days"></i> <span>05/08/2025 — 05/09/2025</span>
                </div>
            </div>
            
            <p class="corp-summary">
                During this intensive virtual engineering internship at CodSoft, I developed production-ready frontend architectures. I focused on responsive layout standards, modern DOM manipulation, and semantic UI frameworks while delivering performance-optimized web software under strict sprint timelines.
            </p>

            <!-- Tasks Sub-Grid -->
            <h4 class="tasks-headline"><i class="fa-solid fa-diagram-project"></i> Core Core Tasks Engineered</h4>
            <div class="tasks-grid-vip">

                <!-- Task 1: Portfolio Website -->
                <div class="task-card-vip">
                    <div class="task-banner portfolio-bg">
                        <i class="fa-solid fa-user-tie task-main-icon"></i>
                    </div>
                    <div class="task-body">
                        <h3>VIP Portfolio Hub</h3>
                        <p>Engineered a highly optimized personal presentation portfolio, featuring responsive fluid grids, asset lazy-loading, and premium custom CSS layout configurations.</p>
                        <div class="task-tech-tags">
                            <span>HTML5</span>
                            <span>CSS3 Glow</span>
                            <span>ES6 JavaScript</span>
                        </div>
                    </div>
                </div>

                <!-- Task 2: Calculator -->
                <div class="task-card-vip">
                    <div class="task-banner calculator-bg">
                        <i class="fa-solid fa-calculator task-main-icon"></i>
                    </div>
                    <div class="task-body">
                        <h3>Smart Matrix Calculator</h3>
                        <p>Developed a clean arithmetic computing engine executing dynamic evaluation functions with an instantaneous responsive input interface.</p>
                        <div class="task-tech-tags">
                            <span>JavaScript</span>
                            <span>DOM Manipulation</span>
                            <span>CSS Grid</span>
                        </div>
                    </div>
                </div>

                <!-- Task 3: Landing Page -->
                <div class="task-card-vip">
                    <div class="task-banner landing-bg">
                        <i class="fa-solid fa-rocket task-main-icon"></i>
                    </div>
                    <div class="task-body">
                        <h3>High-Conversion Landing Page</h3>
                        <p>Designed a modern high-impact digital single-page application focused on aesthetic visual layouts, fluid typography scaling, and high structural conversion mechanics.</p>
                        <div class="task-tech-tags">
                            <span>Flexbox Layouts</span>
                            <span>Keyframe FX</span>
                            <span>Semantic HTML</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

